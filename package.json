{
  "name": "@xifty/xifty",
  "version": "0.1.7",
  "description": "Official Node package for XIFty",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "binding.gyp",
    "dist/**",
    "prebuilds/**",
    "scripts/**",
    "src/**",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XIFtySense/XIFtyNode.git"
  },
  "homepage": "https://github.com/XIFtySense/XIFtyNode#readme",
  "bugs": {
    "url": "https://github.com/XIFtySense/XIFtyNode/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist build",
    "build:ts": "tsc -p tsconfig.json",
    "install": "node scripts/install.js",
    "build": "npm run build:ts && node scripts/build-addon.js release",
    "build:debug": "node scripts/build-addon.js debug",
    "build:prebuilds:local": "node scripts/prebuild.js",
    "build:prebuilds:linux-x64": "node scripts/prebuild-linux-x64.js",
    "build:prebuilds": "node scripts/prebuild-release.js",
    "verify:package": "node scripts/verify-package.js",
    "verify:tarball": "node scripts/smoke-packed-package.js",
    "verify:linux-x64": "node scripts/smoke-linux-x64.js",
    "publish:local": "npm run build:prebuilds && npm run verify:package && npm run verify:tarball && npm run verify:linux-x64 && npm publish --access public",
    "core:prepare": "node -e \"const { ensureCoreCheckout, describeCoreSource } = require('./scripts/core-config'); console.log('Preparing XIFty core from', describeCoreSource()); console.log('Ready at', ensureCoreCheckout());\"",
    "pretest": "npm run build:ts",
    "test": "node --test test/*.test.js",
    "coverage": "c8 node --test test/*.test.js",
    "preexample": "npm run build:ts",
    "prepack": "npm run build:ts",
    "example": "node examples/basic_usage.js",
    "example:gallery": "node examples/gallery_ingest.js"
  },
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "c8": "^11.0.0",
    "node-gyp": "^11.5.0",
    "prebuildify": "^6.0.1",
    "typescript": "^6.0.3"
  }
}
